{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Documentation — Grapevine",
  "description": "Documentation for Grapevine — media, social, and AI monitoring for the modern communications team.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": {
    "light": "/favicon.ico",
    "dark": "/images/favicon.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Contact",
          "icon": "life-buoy",
          "href": "https://grapevine.tech/demo"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Getting started",
        "icon": "rocket",
        "pages": [
          "index",
          "getting-started/quickstart",
          "getting-started/key-concepts"
        ]
      },
      {
        "group": "For you",
        "icon": "layout-dashboard",
        "pages": [
          "intelligence/dashboard",
          "collaboration/agent",
          "monitoring/inbox",
          "monitoring/search"
        ]
      },
      {
        "group": "Monitor",
        "icon": "radar",
        "pages": [
          "monitoring/mentions",
          "monitoring/boards",
          "monitoring/prompts",
          "monitoring/sources",
          "monitoring/entities"
        ]
      },
      {
        "group": "Analyze",
        "icon": "sparkles",
        "pages": [
          "intelligence/analytics",
          "intelligence/insights",
          "intelligence/risk",
          "intelligence/ai-monitoring",
          "collaboration/reports"
        ]
      },
      {
        "group": "Engage",
        "icon": "message-square",
        "pages": ["collaboration/memos"]
      },
      {
        "group": "Configure",
        "icon": "settings",
        "pages": [
          "monitoring/topics",
          "collaboration/workflows",
          "account/settings",
          "account/members",
          "account/notifications",
          "account/billing",
          "account/api-keys"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/grapevine-svg.svg",
    "dark": "/images/grapevine-svg.svg",
    "href": "https://grapevine.tech"
  },
  "navbar": {
    "links": [
      {
        "href": "https://grapevine.tech/#pricing",
        "label": "Pricing"
      },
      {
        "href": "https://grapevine.tech/about",
        "label": "About"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://app.grapevine.tech"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/grapevinetech",
      "linkedin": "https://linkedin.com/company/grapevine-tech"
    }
  },
  "redirects": [
    {
      "source": "/platform/quickstart",
      "destination": "/getting-started/quickstart",
      "permanent": true
    },
    {
      "source": "/platform/key-concepts",
      "destination": "/getting-started/key-concepts",
      "permanent": true
    },
    {
      "source": "/analytics/quickstart",
      "destination": "/intelligence/dashboard",
      "permanent": true
    }
  ],
  "appearance": {
    "default": "light",
    "strict": true
  }
}
